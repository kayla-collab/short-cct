# =============================================================================
# SHORT CIRCUIT - LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .dev.vars and fill in your credentials
# NEVER commit .dev.vars to version control
# =============================================================================

# Stripe API Keys (Live Mode)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here

# Stripe Webhook Secret
# Get from: https://dashboard.stripe.com/webhooks
# Click on your webhook endpoint to reveal the signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Resend Email API Key
# Get from: https://resend.com/api-keys
# NOTE: You must also verify the sending domain (shortcct.com) in Resend
RESEND_API_KEY=re_your_key_here
